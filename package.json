{
  "name": "bandwidth-hero-proxy",
  "version": "1.0.1",
  "description": "Data compression service that converts images to low-res WebP or JPEG on the fly. Used in Bandwidth-Hero browser extension.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun run --env-file=.env src/index.ts",
    "dev": "bun run --watch --env-file=.env src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@napi-rs/image": "^1.12.0",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
