# Server Configuration
PORT=8080
NODE_ENV=production

# Logging Configuration
LOG_LEVEL=info
LOG_ENABLED=true

# Valid LOG_LEVEL values: error, warn, info, debug, trace
# For production, use 'info' or 'warn' for better performance
# For debugging, use 'debug' (verbose) or 'trace' (very verbose)

# Sharp Performance Tuning
# SHARP_CONCURRENCY=4        # Number of CPU cores to use (default: min(CPUs, 4))
# SHARP_CACHE=104857600      # Cache size in bytes (default: 100MB, set to 0 to disable)

# Production Recommendations:
# - Set NODE_ENV=production for optimized error messages
# - Set LOG_LEVEL=info or warn in production (debug/trace are verbose)
# - Adjust SHARP_CONCURRENCY based on your VPS CPU cores
# - Monitor memory usage and adjust SHARP_CACHE if needed
